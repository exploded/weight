# Production flag
PROD=False

# Port the server listens on (default: 8989)
PORT=8990

# Database file path (default: weight.db)
DB_PATH=weight.db

# Monitor portal log shipping (optional — logs WARN+ to the monitor dashboard)
MONITOR_URL=https://monitor.mchugh.au
MONITOR_API_KEY=your-api-key-here

